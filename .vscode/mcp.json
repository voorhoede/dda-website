{
  "servers": {
    "datocms": {
      "command": "npx",
      "args": ["-y", "@datocms/mcp@latest"],
      "env": {
        "DATOCMS_API_TOKEN": "${env:DATOCMS_API_TOKEN}",
        "DATOCMS_ENVIRONMENT": "${env:DATOCMS_ENVIRONMENT}"
      }
    },
    "cloudflare": {
      "url": "https://mcp.cloudflare.com/mcp"
    }
  }
}
