---
import type { AiInternshipsPageQuery } from '@lib/types/datocms';
import Layout from '@layouts/Default.astro';
import { defaultLocale, t } from '@lib/i18n';
import { setCacheControl } from '@lib/cache-control';
import { datocmsRequest } from '@lib/datocms';
import PageHeader from '@blocks/PageHeader/PageHeader.astro';
import { Button } from '@components/Button';
import PreviewModeSubscription from '@components/PreviewMode/PreviewModeSubscription.astro';
import query from './_index.query.graphql';
import { AiInternshipList } from '@blocks/AiInternshipList';

setCacheControl(Astro.response, 0, 10);

const { locale = defaultLocale } = Astro.params;

const { page } = await datocmsRequest<AiInternshipsPageQuery>({
  query,
  variables: { locale },
});

if (!page) {
  return new Response(null, { status: 404 });
}
---

<Layout pageUrls={[]} seoMetaTags={page._seoMetaTags} variant="aiInternships">
  <PreviewModeSubscription query={query} variables={{ locale }} />

  <PageHeader title={page.header.title} subtitle={page.header.subtitle}>
    <Fragment slot="header">
      <Button
        as="a"
        href="/ai-stages/"
        className="back-button"
        level="tertiary"
        icon="arrow-left"
        iconPosition="left"
      >
        {t('back_to_home')}
      </Button>
    </Fragment>
  </PageHeader>

  <AiInternshipList />
</Layout>
